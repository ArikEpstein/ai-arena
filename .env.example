# Copy to .env. With no keys set, everything runs in mock mode (including the Arena) — no edits needed.
#
# To run against real models, fill in your key(s) below and uncomment LLM_MODE=live.
# (`npm test`, `npm run arena`, and `npm run ci` always force mock, even with keys present.)

# LLM_MODE=live
ANTHROPIC_API_KEY=sk-ant-...

# Optional — real semantic RAG + reranking (otherwise a local toy embedder is used):
# VOYAGE_API_KEY=pa-...
# Model overrides — the values below are already the defaults; uncomment only to pin or change them:
# VOYAGE_EMBED_MODEL=voyage-4
# VOYAGE_RERANK_MODEL=rerank-2.5
